---
import Base from "../layouts/Base.astro";
import { BOOKING, WHATSAPP, MAPS, EMAIL, PHONE, PHONE_HREF, ADDRESS } from "../consts";
import data from "../data/kontakt.json";
---
<Base
  title="Kontakt — Hijama Praxis Zürich"
  description="Kontakt zur Hijama Praxis: Riedmühlestrasse 16, 8305 Dietlikon. Telefon/WhatsApp 076 494 97 77, info@hijama-praxis.ch."
>
  <section class="banner">
    <div class="wrap">
      <div class="crumb reveal"><a href="/">Start</a> · Kontakt</div>
      <h1 class="reveal d1">{data.bannerTitle}</h1>
      <p class="reveal d2">{data.bannerSub}</p>
    </div>
  </section>

  <main>
    <section class="block">
      <div class="wrap contact">
        <div>
          <p class="eyebrow reveal">{data.infoEyebrow}</p>
          <div class="cinfo">
            <a href={MAPS} target="_blank" rel="noopener" class="reveal magnetic"><svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 21s7-6.2 7-11a7 7 0 1 0-14 0c0 4.8 7 11 7 11z"/><circle cx="12" cy="10" r="2.5"/></svg><span class="val"><span class="lbl">Praxis</span><b>{ADDRESS}</b></span></a>
            <a href={PHONE_HREF} class="reveal d1 magnetic"><svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 4h3l2 5-2.5 1.5a11 11 0 0 0 5 5L17 13l5 2v3a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2z"/></svg><span class="val"><span class="lbl">Telefon / WhatsApp</span><b>{PHONE}</b></span></a>
            <a href={`mailto:${EMAIL}`} class="reveal d2 magnetic"><svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg><span class="val"><span class="lbl">E-Mail</span><b>{EMAIL}</b></span></a>
            <div class="row reveal d3"><svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg><span class="val"><span class="lbl">Termine</span><b>{data.termineValue}</b></span></div>
          </div>
        </div>
        <div class="contact-cta reveal d1">
          <h3>{data.ctaTitle}</h3>
          <p>{data.ctaText}</p>
          <a href={BOOKING} target="_blank" rel="noopener" class="btn btn-lg magnetic">Jetzt Termin reservieren</a>
          <a href={WHATSAPP} target="_blank" rel="noopener" class="tel">Per WhatsApp schreiben →</a>
        </div>
      </div>
    </section>

    <section class="block alt" style="padding-top:0;background:transparent">
      <div class="wrap reveal">
        <a href={MAPS} target="_blank" rel="noopener" style="display:block;border-radius:20px;overflow:hidden;border:1px solid var(--line);height:340px;background:radial-gradient(60% 80% at 30% 20%,rgba(224,133,106,.35),transparent 60%),linear-gradient(160deg,#FFF1E6,#FCE7DB);position:relative">
          <span style="position:absolute;inset:0;display:grid;place-items:center;text-align:center;color:var(--ink-soft);font-family:var(--serif);font-style:italic;font-size:1.2rem">📍 {ADDRESS}<br /><small style="font-family:var(--sans);font-style:normal">Karte öffnen in Google Maps →</small></span>
        </a>
      </div>
    </section>
  </main>
</Base>
