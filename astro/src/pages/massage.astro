---
import Base from "../layouts/Base.astro";
import { BOOKING } from "../consts";
import data from "../data/massage.json";
---
<Base
  title="Massage & Deep Tissue — Hijama Praxis Zürich"
  description="Massage und Deep Tissue Massage in Dietlikon bei Zürich — Entspannung, Durchblutung und Linderung von Verspannungen."
>
  <section class="banner">
    <div class="wrap">
      <div class="crumb reveal"><a href="/">Start</a> · Behandlungen · Massage</div>
      <h1 class="reveal d1">{data.bannerTitle}</h1>
      <p class="reveal d2">{data.bannerSub}</p>
    </div>
  </section>

  <main>
    <section class="block">
      <div class="wrap prose">
        <p class="eyebrow reveal">{data.introEyebrow}</p>
        <blockquote class="reveal d1">{data.introQuote}</blockquote>
        <h3 class="reveal">{data.wasTitle}</h3>
        <p class="reveal">{data.wasText}</p>
      </div>
    </section>

    <section class="block alt">
      <div class="wrap">
        <div class="sec-head"><p class="eyebrow reveal">{data.wirkungEyebrow}</p><h2 class="reveal d1">{data.wirkungTitle}</h2></div>
        <div class="benefits">
          {data.benefits.map((b, i) => (
            <div class={"benefit reveal" + (i % 2 ? " d1" : "")}><div class="n">✦</div><div><h3>{b.title}</h3><p>{b.text}</p></div></div>
          ))}
        </div>
      </div>
    </section>

    <section class="block">
      <div class="wrap prose">
        <h3 class="reveal">{data.vorteileTitle}</h3>
        <p class="reveal">{data.vorteileText}</p>
        <h3 class="reveal">{data.vorsichtTitle}</h3>
        <p class="reveal">{data.vorsichtText}</p>
      </div>
    </section>

    <section class="block alt">
      <div class="wrap">
        <div class="cta-band reveal">
          <h2>{data.ctaTitle}</h2>
          <p>{data.ctaText}</p>
          <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
            <a href={BOOKING} target="_blank" rel="noopener" class="btn btn-lg magnetic" style="background:#fff;color:var(--magenta)">Termin buchen</a>
            <a href="/preise" class="btn btn-ghost btn-lg magnetic" style="color:#fff;border-color:rgba(255,255,255,.5)">Preise ansehen</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Base>
