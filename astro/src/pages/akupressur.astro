---
import Base from "../layouts/Base.astro";
import { BOOKING } from "../consts";
import data from "../data/akupressur.json";
---
<Base
  title="Akupressur — Hijama Praxis Zürich"
  description="Akupressur (Akupunktmassage) in Dietlikon bei Zürich — prophylaktisch & lösend bei Verspannungen, Schmerzen und vielem mehr."
>
  <section class="banner">
    <div class="wrap">
      <div class="crumb reveal"><a href="/">Start</a> · Behandlungen · Akupressur</div>
      <h1 class="reveal d1">{data.bannerTitle}</h1>
      <p class="reveal d2">{data.bannerSub}</p>
    </div>
  </section>

  <main>
    <section class="block">
      <div class="wrap prose">
        <p class="eyebrow reveal">{data.introEyebrow}</p>
        <blockquote class="reveal d1">{data.introQuote}</blockquote>
        <p class="reveal">{data.introPara}</p>
        <h3 class="reveal">{data.anwendungTitle}</h3>
        <p class="reveal">{data.anwendungText}</p>
      </div>
    </section>

    <section class="block alt">
      <div class="wrap">
        <div class="sec-head"><p class="eyebrow reveal">{data.hilftEyebrow}</p><h2 class="reveal d1">{data.hilftTitle}</h2></div>
        <div class="chiplist reveal d1">
          {data.hilftChips.map((c) => <span class="chip">{c}</span>)}
        </div>
      </div>
    </section>

    <section class="block">
      <div class="wrap prose">
        <h3 class="reveal">{data.behandlungTitle}</h3>
        <p class="reveal">{data.behandlungText}</p>
      </div>
    </section>

    <section class="block alt">
      <div class="wrap">
        <div class="cta-band reveal">
          <h2>{data.ctaTitle}</h2>
          <p>{data.ctaText}</p>
          <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
            <a href={BOOKING} target="_blank" rel="noopener" class="btn btn-lg magnetic" style="background:#fff;color:var(--magenta)">Termin buchen</a>
            <a href="/preise" class="btn btn-ghost btn-lg magnetic" style="color:#fff;border-color:rgba(255,255,255,.5)">Preise ansehen</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Base>
