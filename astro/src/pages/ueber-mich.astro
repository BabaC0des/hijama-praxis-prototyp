---
import Base from "../layouts/Base.astro";
import { BOOKING, SITE } from "../consts";
import data from "../data/ueber-mich.json";
---
<Base
  title="Über mich — Nazmi Bunjaku · Hijama Praxis Zürich"
  description="Nazmi Bunjaku — diplomierter Hijama- & Akupressur-Therapeut in Dietlikon bei Zürich. Werdegang seit 2006."
>
  <section class="banner">
    <div class="wrap">
      <div class="crumb reveal"><a href="/">Start</a> · Über mich</div>
      <h1 class="reveal d1">{data.bannerTitle}</h1>
      <p class="reveal d2">{data.bannerSub}</p>
    </div>
  </section>

  <main>
    <section class="block">
      <div class="wrap" style="display:grid;grid-template-columns:1fr 1.25fr;gap:clamp(36px,6vw,80px);align-items:start">
        <img class="reveal" src="/img/nazmi.jpg" alt="Nazmi Bunjaku — Therapeut" onerror="this.style.opacity=0" style="width:100%;aspect-ratio:4/5;object-fit:cover;border-radius:20px;display:block;border:1px solid var(--line)" />
        <div class="prose">
          <blockquote class="reveal">{SITE.aboutQuote}</blockquote>
          <p class="reveal">{data.introText}</p>
          <h3 class="reveal">{data.werdegangTitle}</h3>
          <div class="timeline reveal">
            {data.timeline.map((t) => (
              <div class="tl"><div class="yr">{t.yr}</div><p>{t.text}</p></div>
            ))}
          </div>
          <h3 class="reveal">{data.methodenTitle}</h3>
          <div class="chiplist reveal">
            {data.methoden.map((m) => <span class="chip">{m}</span>)}
          </div>
        </div>
      </div>
    </section>

    <section class="block alt">
      <div class="wrap">
        <div class="cta-band reveal">
          <h2>{data.ctaTitle}</h2>
          <p>{data.ctaText}</p>
          <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
            <a href={BOOKING} target="_blank" rel="noopener" class="btn btn-lg magnetic" style="background:#fff;color:var(--magenta)">Termin buchen</a>
            <a href="/kontakt" class="btn btn-ghost btn-lg magnetic" style="color:#fff;border-color:rgba(255,255,255,.5)">Kontakt</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Base>
