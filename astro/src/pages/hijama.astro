---
import Base from "../layouts/Base.astro";
import { BOOKING, PHONE, PHONE_HREF } from "../consts";
import data from "../data/hijama.json";
---
<Base
  title="Hijama (Schröpfen) — Hijama Praxis Zürich"
  description="Hijama / Schröpfen in Dietlikon bei Zürich — nass & trocken. Wirkung, Vorteile und Arten der Hijama-Therapie."
>
  <section class="banner">
    <div class="wrap">
      <div class="crumb reveal"><a href="/">Start</a> · Behandlungen · Hijama</div>
      <h1 class="reveal d1">{data.bannerTitle}</h1>
      <p class="reveal d2">{data.bannerSub}</p>
    </div>
  </section>

  <main>
    <section class="block">
      <div class="wrap prose">
        <p class="eyebrow reveal">{data.introEyebrow}</p>
        <blockquote class="reveal d1">{data.introQuote}</blockquote>
        <p class="reveal">{data.introPara1}</p>
        <p class="reveal">{data.introPara2}</p>
        <blockquote class="reveal">{data.introHadith}</blockquote>
      </div>
    </section>

    <section class="block alt">
      <div class="wrap">
        <div class="sec-head"><p class="eyebrow reveal">{data.vorteileEyebrow}</p><h2 class="reveal d1">{data.vorteileTitle}</h2></div>
        <div class="benefits">
          {data.benefits.map((b, i) => (
            <div class={"benefit reveal" + (i % 2 ? " d1" : "")}><div class="n">{i + 1}</div><div><h3>{b.title}</h3><p>{b.text}</p></div></div>
          ))}
        </div>
      </div>
    </section>

    <section class="block">
      <div class="wrap">
        <div class="sec-head"><p class="eyebrow reveal">{data.artenEyebrow}</p><h2 class="reveal d1">{data.artenTitle}</h2></div>
        <div class="grid cols-2">
          {data.arten.map((a, i) => (
            <div class={"tcard reveal" + (i ? " d1" : "")}><span class="tag">{a.tag}</span><h3>{a.title}</h3><p>{a.text}</p></div>
          ))}
        </div>
      </div>
    </section>

    <section class="block alt">
      <div class="wrap" style="max-width:820px">
        <div class="sec-head"><p class="eyebrow reveal">{data.faqEyebrow}</p><h2 class="reveal d1">{data.faqTitle}</h2></div>
        <div class="reveal d1">
          {data.faq.map((f) => (
            <details class="faq"><summary>{f.q}</summary><p>{f.a}</p></details>
          ))}
        </div>
      </div>
    </section>

    <section class="block">
      <div class="wrap">
        <div class="sec-head"><p class="eyebrow reveal">{data.eindrueckeEyebrow}</p><h2 class="reveal d1">{data.eindrueckeTitle}</h2></div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px">
          <figure class="reveal" style="margin:0;aspect-ratio:4/3;border-radius:16px;overflow:hidden;position:relative;background:var(--grad-soft);border:1px solid var(--line);display:grid;place-items:center;color:var(--ink-faint);font-size:.72rem;text-align:center;padding:8px">Schröpfgläser<img src="/img/cupping-set.jpg" alt="Schröpfgläser" onerror="this.remove()" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover" /></figure>
          <figure class="reveal d1" style="margin:0;aspect-ratio:4/3;border-radius:16px;overflow:hidden;position:relative;background:var(--grad-soft);border:1px solid var(--line);display:grid;place-items:center;color:var(--ink-faint);font-size:.72rem;text-align:center;padding:8px">Feuerschröpfen<img src="/img/feuer-cupping.jpg" alt="Feuerschröpfen" onerror="this.remove()" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover" /></figure>
        </div>
      </div>
    </section>

    <section class="block">
      <div class="wrap">
        <div class="cta-band reveal">
          <h2>{data.ctaTitle}</h2>
          <p>{data.ctaText}</p>
          <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
            <a href={BOOKING} target="_blank" rel="noopener" class="btn btn-lg magnetic" style="background:#fff;color:var(--magenta)">Termin buchen</a>
            <a href={PHONE_HREF} class="btn btn-ghost btn-lg magnetic" style="color:#fff;border-color:rgba(255,255,255,.5)">{PHONE}</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <style>
    details.faq { border-bottom: 1px solid var(--line); padding: 18px 0; }
    details.faq summary { font-family: var(--serif); font-size: 1.25rem; color: var(--plum); cursor: pointer; list-style: none; display: flex; justify-content: space-between; gap: 16px; }
    details.faq summary::-webkit-details-marker { display: none; }
    details.faq summary::after { content: "+"; color: var(--magenta); font-size: 1.4rem; }
    details.faq[open] summary::after { content: "–"; }
    details.faq p { color: var(--ink-soft); margin-top: 0.8rem; }
  </style>
</Base>
